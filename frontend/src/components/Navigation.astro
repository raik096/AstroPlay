---
// src/components/Navigation.astro
let navPages = []; // Inizializziamo sempre come array vuoto

try {
    const response = await fetch('http://localhost:3000/api/pages?limit=5');
    
    if (response.ok) {
        const data = await response.json();
        // Usiamo l'operatore "Optional Chaining" (?.) e un fallback (|| [])
        navPages = data?.docs || [];
    }
} catch (error) {
    console.error("Incapace di recuperare il menu dal CMS:", error);
    // Se fallisce, navPages rimane un array vuoto e il sito non crasha
}
---

<nav>
    <a href="/">CLIENT-SR</a>
    <a href="/news">SERVER-SR</a>
    <a href="/about">ABOUT POC</a>
    
    {navPages && navPages.map((page: any) => (
        <a href={`/${page.slug}`}>{page.title}</a>
    ))}
</nav>

<style>
    /* Aggiungi un po' di stile per renderlo guardabile */
    nav { display: flex; gap: 1.5rem; padding: 1rem; background: #f8fafc; border-bottom: 1px solid #e2e8f0; }
    nav a { text-decoration: none; color: #1e293b; font-weight: 500; }
    nav a:hover { color: #2563eb; }
</style>