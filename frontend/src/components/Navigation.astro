---
// src/components/Navigation.astro

let menuItems = [];

try {
  // Aggiungiamo depth=1 per farci espandere la relazione e ottenere lo 'slug' della pagina
  const response = await fetch('http://127.0.0.1:3000/api/navigation?sort=order&depth=1');
  const data = await response.json();
  menuItems = data.docs;
} catch (error) {
  console.error("🚨 Errore fetch menu:", error);
}
---

<nav class="navbar navbar-expand-md bg-white border-top border-bottom rt-main-menu" id="navigationCollapse">
  <div class="rt-container">
    <ul class="navbar-nav mr-auto d-flex flex-row gap-4">
      
      {/* Link fisso alla Home */}
      <li class="nav-item">
        <a class="nav-link" href="/">Home</a>
      </li>

      {/* Ciclo dinamico sulle pagine di Payload */}
      {menuItems.map((item: any) => {
        // Estraiamo lo slug dalla pagina relazionata (se esiste)
        const slug = item.page?.slug; 
        // Se non c'è lo slug, puntiamo a # come fallback
        const href = slug ? `/${slug}` : '#';

        return (
          <li class="nav-item">
            <a class="nav-link" href={href}>
              {item.label}
            </a>
          </li>
        );
      })}

    </ul>
  </div>
</nav>

<style>
  /* Aggiungiamo un po' di stile per farlo sembrare proprio quello della Regione */
  .rt-main-menu {
    box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
  }
  .navbar-nav {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 2rem;
  }
  .nav-link {
    font-weight: 600;
    color: #2d4156 !important;
    text-transform: uppercase;
    font-size: 0.9rem;
    padding: 1rem 0 !important;
    transition: color 0.2s ease;
  }
  .nav-link:hover {
    color: #e98b2d !important; /* Il colore arancione/giallo del tema */
  }
</style>