---
// Riceviamo i dati definiti nel file HeroBlock.ts
const { heading, subheading } = Astro.props;
---

<section class="hero">
  <div class="hero-content">
    <h1>{heading}</h1>
    {subheading && <p>{subheading}</p>}
  </div>
</section>

<style>
  .hero {
    background: #0f172a;
    color: white;
    padding: 6rem 2rem;
    text-align: center;
    border-radius: 12px;
    margin-bottom: 2rem;
  }
  h1 { font-size: 3.5rem; margin: 0; line-height: 1.1; }
  p { font-size: 1.25rem; opacity: 0.8; margin-top: 1rem; }
</style>