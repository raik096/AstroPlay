---
const { formTitle, formType, showPrivacyCheckbox } = Astro.props;
---

<section class="form-section">
  <div class="form-wrapper">
    <h2>{formTitle}</h2>
    <span class="badge">{formType}</span>
    
    <form>
      <input type="text" placeholder="Nome" />
      <input type="email" placeholder="Email" />
      <textarea placeholder="Messaggio"></textarea>
      
      {showPrivacyCheckbox && (
        <label>
          <input type="checkbox" required /> Accetto i termini della Privacy
        </label>
      )}
      
      <button type="submit">Invia al sistema</button>
    </form>
  </div>
</section>

<style>
  .form-section { background: #f1f5f9; padding: 4rem 2rem; border-radius: 12px; }
  .form-wrapper { max-width: 500px; margin: 0 auto; }
  h2 { margin-bottom: 0.5rem; }
  .badge { font-size: 0.7rem; background: #3b82f6; color: white; padding: 2px 8px; border-radius: 10px; }
  form { display: flex; flex-direction: column; gap: 1rem; margin-top: 2rem; }
  input, textarea { padding: 10px; border: 1px solid #cbd5e1; border-radius: 4px; }
  button { background: #0f172a; color: white; padding: 12px; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; }
</style>