---
// src/pages/[slug].astro
import BaseLayout from '../layouts/BaseLayout.astro';

// 1. IMPORTA I TUOI COMPONENTI (I "Mattoncini")
import Hero from '../components/blocks/Hero.astro';
import TextImage from '../components/blocks/TextImage.astro';
import FormBlock from '../components/blocks/FormBlock.astro';
import ServiziSection from '../components/blocks/ServiziSection.astro';

export const prerender = false;

const { slug } = Astro.params;
let pageData = null;

try {
    const response = await fetch(`http://127.0.0.1:3000/api/pages?where[slug][equals]=${slug}`);
    const data = await response.json();
    pageData = data.docs[0];
} catch (e) {
    console.error("🚨 Errore fetch pagina:", e);
}

if (!pageData) {
    return Astro.redirect('/404');
}

// 2. LA MAPPA DEI COMPONENTI
const blockComponents = {
    hero: Hero,
    textImage: TextImage,
    formBlock: FormBlock, 
    // 👇 AGGIUNGI QUESTA RIGA 👇 (Assicurati che la chiave sia lo slug esatto usato in Payload)
    serviziSection: ServiziSection, 
};
---

<BaseLayout pageTitle={pageData.title}>
    <article class="dynamic-page">
        {pageData.layout && pageData.layout.map((block: any) => {
            const Component = blockComponents[block.blockType as keyof typeof blockComponents];
            
            if (!Component) {
                return (
                    <div class="debug-warning">
                        ⚠️ Blocco "{block.blockType}" non ancora implementato su Astro.
                    </div>
                );
            }

            return <Component {...block} />;
        })}
    </article>
</BaseLayout>

<style>
    .dynamic-page { 
        width: 100%;
        margin: 0 auto;
    }

    .debug-warning {
        background: #fef3c7;
        color: #92400e;
        padding: 1rem;
        margin: 1rem;
        border: 1px dashed #f59e0b;
        border-radius: 8px;
        text-align: center;
        font-family: monospace;
    }
</style>