---
// src/pages/news/[id].astro
import BaseLayout from '../../layouts/BaseLayout.astro';


export const prerender = false;

const { id } = Astro.params;

let article = null;
let errorMessage = null;

try {
    const response = await fetch(`http://localhost:3000/api/news/${id}`);
    
    if (!response.ok) {
        throw new Error('Articolo non trovato');
    }
    
    article = await response.json();
} catch (error: any) {
    errorMessage = error.message;
}

const pageTitle = article ? article.title : "Notizia Non Trovata";
---

<BaseLayout pageTitle={pageTitle}>
    <main class="article-container">
        <a href="/news" class="back-link">&larr; Torna all'elenco</a>

        {errorMessage ? (
            <div class="error-box">
                <h2>Errore 404</h2>
                <p>{errorMessage}</p>
            </div>
        ) : (
            <article class="full-article">
                <header class="article-header">
                    <span class="category">{article.category}</span>
                    <h1>{article.title}</h1>
                    <time>Pubblicato il: {new Date(article.createdAt).toLocaleDateString()}</time>
                </header>

                <div class="article-excerpt">
                    <strong>Riassunto:</strong> {article.excerpt}
                </div>
            </article>
        )}
    </main>

    <style>
        .article-container { max-width: 800px; margin: 0 auto; padding: 3rem 1rem; font-family: sans-serif; color: #1e293b; }
        .back-link { display: inline-block; margin-bottom: 2rem; color: #2563eb; text-decoration: none; font-weight: 600; }
        .back-link:hover { text-decoration: underline; }
        .article-header { border-bottom: 1px solid #e2e8f0; padding-bottom: 2rem; margin-bottom: 2rem; }
        .category { background: #f1f5f9; padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: bold; text-transform: uppercase; color: #475569; display: inline-block; margin-bottom: 1rem; }
        .article-header h1 { font-size: 2.5rem; margin: 0 0 1rem 0; color: #0f172a; line-height: 1.2; }
        .article-header time { color: #64748b; font-size: 0.9rem; }
        .article-excerpt { font-size: 1.2rem; line-height: 1.6; color: #334155; background: #f8fafc; padding: 1.5rem; border-left: 4px solid #94a3b8; margin-bottom: 2rem; }
    </style>
</BaseLayout>